<%- include('partials/scripts') %>
<script>
  // Show success toast
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('success') === 'true') {
    const toastElement = document.getElementById('successToast');
    toastElement.style.display = 'flex';
    new bootstrap.Toast(toastElement).show();
    window.history.replaceState({}, document.title, window.location.pathname);
  }

if (urlParams.get('login') === 'success') {
  const loginModal = new bootstrap.Modal(document.getElementById('loginSuccessModal'));
  loginModal.show();
  window.history.replaceState({}, document.title, window.location.pathname);
}

$("#familyBtn").on("click", function () {
  $.get("/family/check", function (res) {
    if (res.exists) {
      window.location.href = "/my-family";
    } else {
      showFamilyModal(
        "No Details Found",
        "No family details found. Please add your family details.",
        "Add Family",
        "/family-form"
      );
    }
  });
});

function showFamilyModal(title, msg, btnText, redirectUrl) {
  $("#familyModalTitle").text(title);
  $("#familyModalMsg").text(msg);
  $("#familyModalAction").text(btnText);

  const modal = new bootstrap.Modal(document.getElementById("familyStatusModal"));
  modal.show();

  $("#familyModalAction").off("click").on("click", function () {
    modal.hide();
    window.location.href = redirectUrl;
  });
}

  function showComingSoonModal() {
    new bootstrap.Modal(document.getElementById('comingSoonModal')).show();
  }

  function handleFamilyClick() {
    if (sessionStorage.getItem('backFromMyFamily') === 'true') {
      sessionStorage.removeItem('backFromMyFamily');
      window.location.href = '/my-family';
      return;
    }

  // Otherwise, show the modal
  const modal = new bootstrap.Modal(document.getElementById('familyCheckModal'));
  modal.show();
}

const familyModal = document.getElementById('familyCheckModal');
familyModal.addEventListener('show.bs.modal', function (event) {
  // Prevent modal from showing if returning from my-family page
  if (sessionStorage.getItem('backFromMyFamily') === 'true') {
    event.preventDefault();
    sessionStorage.removeItem('backFromMyFamily');
    window.location.href = '/my-family';
    return;
  }

  const familyContent = document.getElementById('familyContent');

  familyContent.innerHTML = `
    <div class="text-center">
      <div class="spinner-border"></div>
    </div>
  `;

  fetch('/my-family-json')
    .then(response => response.json())
    .then(data => {
      if (data.success && data.members && data.members.length > 0) {
        // If family details exist, hide modal and redirect directly to /my-family
        const modal = bootstrap.Modal.getInstance(document.getElementById('familyCheckModal'));
        modal.hide();
        sessionStorage.setItem('backFromMyFamily', 'true');
        window.location.href = '/my-family';
      } else {
        familyContent.innerHTML = `
          <div class="text-center">
            <div class="alert alert-warning">
              <h5>Add Details</h5>
              <p>No family details found. Please add your family details.</p>
              <button class="btn btn-primary" onclick="window.location.href='/family-form'">
                Add Details
              </button>
            </div>
          `;
          new bootstrap.Modal(document.getElementById('familyCheckModal')).show();
        }
      })
      .catch(err => {
        console.error(err);
        const familyContent = document.getElementById('familyContent');
        familyContent.innerHTML = `
          <div class="text-center py-3">
            <i class="bi bi-x-circle text-danger mb-3" style="font-size: 3rem;"></i>
            <h5 class="fw-bold mb-3">Error Loading Family Details</h5>
            <p class="text-muted">Please try again later.</p>
          </div>
        `;
        new bootstrap.Modal(document.getElementById('familyCheckModal')).show();
      });
  }

  // Card hover effects
  document.querySelectorAll('.card[style*="cursor: pointer"]').forEach(card => {
    card.addEventListener('mouseenter', function() {
      this.style.transform = 'translateY(-4px)';
      this.style.boxShadow = 'var(--shadow-lg)';
    });
    card.addEventListener('mouseleave', function() {
      this.style.transform = 'translateY(0)';
      this.style.boxShadow = 'var(--shadow-sm)';
    });
  });

</script>
</body>
