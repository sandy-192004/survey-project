<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

  <body class="d-flex flex-column min-vh-100">

    <%- include('partials/navbar') %>

      <div class="container-fluid px-3 px-md-4 py-4" style="flex: 1; background-color: var(--gray-50);">

        <!-- Page Header -->
        <div class="mb-4 d-flex justify-content-between align-items-center">
          <h1 class="h3 fw-bold mb-0"><i class="bi bi-pencil-fill text-primary me-2"></i>Edit Family</h1>
          <a href="/dashboard" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
        </div>

        <style>
          .card {
            border: 1px solid var(--border-color);
            border-radius: 10px;
            background-color: #ffffff;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
          }

          .btn-primary {
            background-color: var(--primary);
            border-color: var(--primary);
          }

          .btn-primary:hover {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
          }

          .img-thumbnail {
            max-height: 150px;
            object-fit: cover;
            display: none;
            margin-top: 8px;
          }

          .section-title {
            color: var(--primary);
            font-weight: 600;
            border-bottom: 2px solid var(--primary);
            padding-bottom: 8px;
            margin-bottom: 16px;
          }

          .sibling-section {
            display: none;
          }

          .sibling-card {
            background-color: #f8f9fa;
            border: 1px dashed #dee2e6;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
          }
        </style>

        <form id="familyForm" action="/update-family-full/<%= family.id %>" enctype="multipart/form-data">

          <div class="row g-2">
            <div class="col-12">
              <div class="card p-4">

                <!-- ===== HUSBAND SIDE SECTION ===== -->
                <div class="mb-4">
                  <h4 class="section-title"><i class="bi bi-person-badge me-2"></i>Husband Side</h4>

                  <div class="row g-2">
                    <!-- Husband (Current User - Auto-filled) -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2 text-muted">Husband (You)</h6>
                      <input class="form-control mb-2 small" name="husband_name" placeholder="Husband Name" required>
                      <select class="form-control mb-2 small" name="husband[gender]">
                        <option value="Male" selected>Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                      </select>
                      <input class="form-control mb-2 small" name="husband[mobile]" placeholder="Husband Mobile"
                        type="tel">
                      <input class="form-control mb-2 small" name="husband[occupation]"
                        placeholder="Husband Occupation">

                      <label class="form-label small">Photo</label>
                      <input type="file" id="husband_photo_file" class="form-control small d-none" name="husband[photo]"
                        accept="image/*" onchange="handlePhotoSelect(this, 'husband')">
                      <div id="husband_placeholder"
                        class="d-flex align-items-center justify-content-center position-relative"
                        style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;"
                        onclick="showPhotoOptions('husband')">
                        <span class="text-muted">Click to upload photo</span>
                      </div>
                    </div>

                    <!-- Husband Father -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2 text-muted">Husband's Father</h6>
                      <input class="form-control mb-2 small" name="husband[father_name]" placeholder="Father Name">
                      <input class="form-control mb-2 small" name="husband[father_occupation]"
                        placeholder="Father Occupation">

                      <label class="form-label small">Father Photo</label>
                      <input type="file" id="husband_father_photo_file" class="form-control small d-none"
                        name="husband[father_photo]" accept="image/*"
                        onchange="handlePhotoSelect(this, 'husband_father')">
                      <div id="husband_father_placeholder"
                        class="d-flex align-items-center justify-content-center position-relative"
                        style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;"
                        onclick="showPhotoOptions('husband_father')">
                        <span class="text-muted">Click to upload photo</span>
                      </div>
                    </div>

                    <!-- Husband Mother -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2 text-muted">Husband's Mother</h6>
                      <input class="form-control mb-2 small" name="husband[mother_name]" placeholder="Mother Name">
                      <input class="form-control mb-2 small" name="husband[mother_occupation]"
                        placeholder="Mother Occupation">

                      <label class="form-label small">Mother Photo</label>
                      <input type="file" id="husband_mother_photo_file" class="form-control small d-none"
                        name="husband[mother_photo]" accept="image/*"
                        onchange="handlePhotoSelect(this, 'husband_mother')">
                      <div id="husband_mother_placeholder"
                        class="d-flex align-items-center justify-content-center position-relative"
                        style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;"
                        onclick="showPhotoOptions('husband_mother')">
                        <span class="text-muted">Click to upload photo</span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- ===== WIFE SIDE SECTION ===== -->
                <div class="mb-4">
                  <h4 class="section-title"><i class="bi bi-person-badge-fill me-2"></i>Wife Side</h4>

                  <div class="row g-2">
                    <!-- Wife -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2 text-muted">Wife</h6>
                      <input class="form-control mb-2 small" name="wife[name]" placeholder="Wife Name">
                      <select class="form-control mb-2 small" name="wife[gender]">
                        <option value="Female" selected>Female</option>
                        <option value="Male">Male</option>
                        <option value="Other">Other</option>
                      </select>
                      <input class="form-control mb-2 small" name="wife[mobile]" placeholder="Wife Mobile" type="tel">
                      <input class="form-control mb-2 small" name="wife[occupation]" placeholder="Wife Occupation">

                      <label class="form-label small">Photo</label>
                      <input type="file" id="wife_photo_file" class="form-control small d-none" name="wife[photo]"
                        accept="image/*" onchange="handlePhotoSelect(this, 'wife')">
                      <div id="wife_placeholder"
                        class="d-flex align-items-center justify-content-center position-relative"
                        style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;"
                        onclick="showPhotoOptions('wife')">
                        <span class="text-muted">Click to upload photo</span>
                      </div>
                    </div>

                    <!-- Wife Father -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2 text-muted">Wife's Father</h6>
                      <input class="form-control mb-2 small" name="wife[father_name]" placeholder="Father Name">
                      <input class="form-control mb-2 small" name="wife[father_occupation]"
                        placeholder="Father Occupation">

                      <label class="form-label small">Father Photo</label>
                      <input type="file" id="wife_father_photo_file" class="form-control small d-none"
                        name="wife[father_photo]" accept="image/*" onchange="handlePhotoSelect(this, 'wife_father')">
                      <div id="wife_father_placeholder"
                        class="d-flex align-items-center justify-content-center position-relative"
                        style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;"
                        onclick="showPhotoOptions('wife_father')">
                        <span class="text-muted">Click to upload photo</span>
                      </div>
                    </div>

                    <!-- Wife Mother -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2 text-muted">Wife's Mother</h6>
                      <input class="form-control mb-2 small" name="wife[mother_name]" placeholder="Mother Name">
                      <input class="form-control mb-2 small" name="wife[mother_occupation]"
                        placeholder="Mother Occupation">

                      <label class="form-label small">Mother Photo</label>
                      <input type="file" id="wife_mother_photo_file" class="form-control small d-none"
                        name="wife[mother_photo]" accept="image/*" onchange="handlePhotoSelect(this, 'wife_mother')">
                      <div id="wife_mother_placeholder"
                        class="d-flex align-items-center justify-content-center position-relative"
                        style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;"
                        onclick="showPhotoOptions('wife_mother')">
                        <span class="text-muted">Click to upload photo</span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- ===== SIBLINGS SECTION ===== -->
                <div class="mb-4">
                  <h4 class="section-title"><i class="bi bi-people me-2"></i>Siblings</h4>

                  <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="hasSiblings" name="siblings[has_siblings]"
                      onchange="toggleSiblingsSection()">
                    <label class="form-check-label" for="hasSiblings">
                      <strong>Do you have siblings?</strong>
                    </label>
                  </div>

                  <div id="siblingsSection" class="siblings-section">
                    <div class="row g-2">
                      <!-- Husband Side Siblings -->
                      <div class="col-12 col-md-6">
                        <h6 class="mb-2 text-muted">Husband's Siblings</h6>
                        <div id="husbandSiblingsContainer"></div>
                        <button type="button" class="btn btn-outline-primary btn-sm mt-2"
                          onclick="addSibling('husband')">
                          <i class="bi bi-plus-circle me-1"></i>Add Husband's Sibling
                        </button>
                      </div>

                      <!-- Wife Side Siblings -->
                      <div class="col-12 col-md-6">
                        <h6 class="mb-2 text-muted">Wife's Siblings</h6>
                        <div id="wifeSiblingsContainer"></div>
                        <button type="button" class="btn btn-outline-primary btn-sm mt-2" onclick="addSibling('wife')">
                          <i class="bi bi-plus-circle me-1"></i>Add Wife's Sibling
                        </button>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- ===== CHILDREN SECTION ===== -->
                <div class="mb-4">
                  <h4 class="section-title"><i class="bi bi-heart-fill me-2"></i>Children</h4>
                  <div id="children" class="mb-3"></div>

                  <button type="button" class="btn btn-secondary btn-sm mb-3" onclick="addChild()">
                    <i class="bi bi-plus-circle me-1"></i>Add Child
                  </button>
                </div>

                <!-- ===== ADDRESS ===== -->
                <div class="mb-4">
                  <h4 class="section-title"><i class="bi bi-house-fill me-2"></i>Address</h4>
                  <div class="row g-2">
                    <div class="col-12 col-md-6">
                      <input class="form-control mb-2 small" name="address[door_no]" placeholder="Door No">
                      <input class="form-control mb-2 small" name="address[street]" placeholder="Street">
                    </div>

                    <div class="col-12 col-md-6">
                      <select class="form-control mb-2 small" name="address[state]" id="state">
                        <option value="">Select State</option>
                      </select>

                      <select class="form-control mb-2 small" name="address[district]" id="district">
                        <option value="">Select District</option>
                      </select>
                    </div>
                  </div>
                  <input class="form-control mb-3 small" name="address[pincode]" placeholder="Pincode" type="text">
                </div>

                <!-- ===== SAVE BUTTON ===== -->
                <div class="mt-4 text-center">
                  <button type="submit" class="btn btn-primary px-5">
                    <i class="bi bi-check-lg me-2"></i>Save Family
                  </button>
                </div>

              </div>
            </div>
          </div>

        </form>

      </div>

      <%- include('partials/footer') %>

        <!-- SweetAlert2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

        <%- include('partials/scripts') %>
          <script src="/js/family-tree-edit.js"></script>

          <!-- Script to Auto-Fill Data on Edit -->
          <script id="members-data" type="application/json"><%- JSON.stringify(members || []) %></script>
          <script>
            // Data passed from controller
            const membersData = JSON.parse(document.getElementById('members-data').textContent);

            function getValueSafely(memberType, relationship, field) {
              const member = membersData.find(m => m.member_type === memberType && (m.relationship === relationship || m.relation_type === relationship));
              return member ? member[field] || '' : '';
            }

            // A helper to populate an input element securely
            function setInputSafely(name, value) {
              const el = document.querySelector(`input[name="${name}"], select[name="${name}"]`);
              if (el && value) el.value = value;
            }

            document.addEventListener('DOMContentLoaded', () => {
              // Husband
              const husband = membersData.find(m => m.relationship === 'husband');
              if (husband) {
                setInputSafely('husband_name', husband.name);
                setInputSafely('husband[gender]', husband.gender || 'Male');
                setInputSafely('husband[mobile]', husband.mobile);
                setInputSafely('husband[occupation]', husband.occupation);
                // Also load address
                setInputSafely('address[door_no]', husband.door_no);
                setInputSafely('address[street]', husband.street);
                setInputSafely('address[pincode]', husband.pincode);
                setTimeout(() => {
                  setInputSafely('address[state]', husband.state);
                  // Fire change so districts load? Wait, districts load on change.
                  const stateDropdown = document.getElementById('state');
                  if (stateDropdown) {
                    stateDropdown.dispatchEvent(new Event('change'));
                    setTimeout(() => setInputSafely('address[district]', husband.district), 500);
                  }
                }, 500);

                // Show existing photos
                if (husband.photo) {
                  const pEl = document.getElementById('husband_placeholder');
                  pEl.innerHTML = `<img src="/${husband.photo.replace('uploads/', '')}" style="max-height: 100px;">`;
                }
              }

              // Husband Father
              const hFather = membersData.find(m => m.member_type === 'husband_parent' && m.relationship === 'father');
              if (hFather) {
                setInputSafely('husband[father_name]', hFather.name);
                setInputSafely('husband[father_occupation]', hFather.occupation);
                if (hFather.photo) {
                  document.getElementById('husband_father_placeholder').innerHTML = `<img src="/${hFather.photo.replace('uploads/', '')}" style="max-height: 100px;">`;
                }
              }

              // Husband Mother
              const hMother = membersData.find(m => m.member_type === 'husband_parent' && m.relationship === 'mother');
              if (hMother) {
                setInputSafely('husband[mother_name]', hMother.name);
                setInputSafely('husband[mother_occupation]', hMother.occupation);
                if (hMother.photo) {
                  document.getElementById('husband_mother_placeholder').innerHTML = `<img src="/${hMother.photo.replace('uploads/', '')}" style="max-height: 100px;">`;
                }
              }

              // Wife
              const wife = membersData.find(m => m.relationship === 'wife');
              if (wife) {
                setInputSafely('wife[name]', wife.name);
                setInputSafely('wife[gender]', wife.gender || 'Female');
                setInputSafely('wife[mobile]', wife.mobile);
                setInputSafely('wife[occupation]', wife.occupation);
                if (wife.photo) {
                  document.getElementById('wife_placeholder').innerHTML = `<img src="/${wife.photo.replace('uploads/', '')}" style="max-height: 100px;">`;
                }
              }

              // Wife Father
              const wFather = membersData.find(m => m.member_type === 'wife_parent' && m.relationship === 'father');
              if (wFather) {
                setInputSafely('wife[father_name]', wFather.name);
                setInputSafely('wife[father_occupation]', wFather.occupation);
                if (wFather.photo) {
                  document.getElementById('wife_father_placeholder').innerHTML = `<img src="/${wFather.photo.replace('uploads/', '')}" style="max-height: 100px;">`;
                }
              }

              // Wife Mother
              const wMother = membersData.find(m => m.member_type === 'wife_parent' && m.relationship === 'mother');
              if (wMother) {
                setInputSafely('wife[mother_name]', wMother.name);
                setInputSafely('wife[mother_occupation]', wMother.occupation);
                if (wMother.photo) {
                  document.getElementById('wife_mother_placeholder').innerHTML = `<img src="/${wMother.photo.replace('uploads/', '')}" style="max-height: 100px;">`;
                }
              }

              // Load Children & Siblings by extending window variables
              const sHusband = membersData.filter(m => m.member_type === 'husband_sibling');
              const sWife = membersData.filter(m => m.member_type === 'wife_sibling');
              if (sHusband.length > 0 || sWife.length > 0) {
                document.getElementById('hasSiblings').checked = true;
                toggleSiblingsSection();
                sHusband.forEach(sh => {
                  const idx = siblingIndex.husband;
                  addSibling('husband');
                  setTimeout(() => {
                    setInputSafely(`siblings[husband][${idx}][name]`, sh.name);
                    setInputSafely(`siblings[husband][${idx}][gender]`, sh.gender);
                    setInputSafely(`siblings[husband][${idx}][relationship]`, sh.relationship);
                    setInputSafely(`siblings[husband][${idx}][occupation]`, sh.occupation);
                  }, 50);
                });
                sWife.forEach(sw => {
                  const idx = siblingIndex.wife;
                  addSibling('wife');
                  setTimeout(() => {
                    setInputSafely(`siblings[wife][${idx}][name]`, sw.name);
                    setInputSafely(`siblings[wife][${idx}][gender]`, sw.gender);
                    setInputSafely(`siblings[wife][${idx}][relationship]`, sw.relationship);
                    setInputSafely(`siblings[wife][${idx}][occupation]`, sw.occupation);
                  }, 50);
                });
              }

              const childrenData = membersData.filter(m => m.member_type === 'child');
              childrenData.forEach(c => {
                const idx = childIndex;
                addChild();
                setTimeout(() => {
                  setInputSafely(`children[${idx}][name]`, c.name);
                  setInputSafely(`children[${idx}][dob]`, c.dob ? new Date(c.dob).toISOString().split('T')[0] : '');
                  setInputSafely(`children[${idx}][gender]`, c.gender);
                  setInputSafely(`children[${idx}][occupation]`, c.occupation);
                }, 50);
              });

              // Also change button text
              const submitBtn = document.querySelector('button[type="submit"]');
              if (submitBtn) {
                submitBtn.innerHTML = '<i class="bi bi-check-lg me-2"></i>Update Family';
              }
            });
          </script>

          <script>
            let siblingIndex = { husband: 0, wife: 0 };
            let childIndex = 0;

            // Toggle siblings section visibility
            function toggleSiblingsSection() {
              const checkbox = document.getElementById('hasSiblings');
              const section = document.getElementById('siblingsSection');
              section.style.display = checkbox.checked ? 'block' : 'none';
            }

            // Add sibling fields
            function addSibling(side) {
              const container = document.getElementById(side + 'SiblingsContainer');
              const index = siblingIndex[side];

              const html = `
    <div class="sibling-card" id="sibling-${side}-${index}">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="fw-semibold">${side === 'husband' ? 'Husband' : 'Wife'} Side Sibling ${index + 1}</span>
        <button type="button" class="btn btn-danger btn-sm" onclick="removeSibling('${side}', ${index})">❌ Remove</button>
      </div>
      <input class="form-control mb-2 small" name="siblings[${side}][${index}][name]" placeholder="Sibling Name" required>
      <select class="form-control mb-2 small" name="siblings[${side}][${index}][gender]">
        <option value="">Select Gender</option>
        <option value="Male">Male</option>
        <option value="Female">Female</option>
      </select>
      <select class="form-control mb-2 small" name="siblings[${side}][${index}][relationship]">
        <option value="">Relationship</option>
        <option value="brother">Brother</option>
        <option value="sister">Sister</option>
      </select>
      <input class="form-control mb-2 small" name="siblings[${side}][${index}][occupation]" placeholder="Occupation">
      <label class="form-label small">Photo</label>
      <input type="file" id="sibling_${side}_${index}_file" class="form-control small d-none" 
             name="siblings[${side}][${index}][photo]" accept="image/*"
             onchange="handlePhotoSelect(this, 'sibling_${side}_${index}')">
      <div id="sibling_${side}_${index}_placeholder" class="d-flex align-items-center justify-content-center position-relative" 
           style="height: 100px; background-color: #f8f9fa; border: 1px dashed #dee2e6; cursor: pointer;" 
           onclick="showPhotoOptions('sibling_${side}_${index}')">
        <span class="text-muted">Click to upload photo</span>
      </div>
    </div>
  `;

              container.insertAdjacentHTML('beforeend', html);
              siblingIndex[side]++;
            }

            // Remove sibling fields
            function removeSibling(side, index) {
              const el = document.getElementById(`sibling-${side}-${index}`);
              if (el) el.remove();
            }

            // Check if in add child mode
            const urlParams = new URLSearchParams(window.location.search);
            const mode = urlParams.get('mode');

            if (mode === 'addChild') {
              // Hide parent section
              const parentSection = document.getElementById('parentSection');
              if (parentSection) {
                parentSection.style.display = 'none';
              }

              // Change page title
              const pageTitle = document.querySelector('h1');
              if (pageTitle) {
                pageTitle.innerHTML = '<i class="bi bi-person-plus-fill text-success me-2"></i>Add Child';
              }

              // Change submit button text
              const submitBtn = document.querySelector('button[type="submit"]');
              if (submitBtn) {
                submitBtn.innerHTML = '<i class="bi bi-check-lg me-2"></i>Save Child';
              }

              // Auto-add one child form
              setTimeout(() => addChild(), 100);
            }
          </script>

  </body>

</html>