<!DOCTYPE html>
<html lang="en">

<head>
  <title>Admin Dashboard - Family Portal</title>
  <%- include('../partials/head') %>
    <style>
      .family-tree-modal .modal-body {
        max-height: 80vh;
        overflow-y: auto;
      }

      .tree-container {
        padding: 20px;
        text-align: center;
      }

      .tree-level {
        display: flex;
        justify-content: center;
        gap: 30px;
        margin-bottom: 30px;
        position: relative;
      }

      .tree-level::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: #dee2e6;
        z-index: 0;
      }

      .tree-node {
        display: inline-block;
        position: relative;
        z-index: 1;
        background: white;
        padding: 10px;
        border-radius: 10px;
      }

      .tree-photo {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #6f4e37;
        margin-bottom: 8px;
      }

      .tree-photo-placeholder {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #f8f9fa;
        border: 3px dashed #dee2e6;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 8px;
      }

      .tree-name {
        font-weight: 600;
        font-size: 14px;
        margin-bottom: 4px;
      }

      .tree-relation {
        font-size: 12px;
        color: #6c757d;
      }

      .tree-connector {
        width: 2px;
        height: 30px;
        background: #dee2e6;
        margin: 0 auto;
      }

      .tree-spouse-line {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .family-tree-btn {
        background: #6f4e37;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 12px;
        cursor: pointer;
      }

      .family-tree-btn:hover {
        background: #5a3e2b;
      }

      .loading-spinner {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
      }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

  <%- include('../partials/admin-navbar') %>

    <main class="flex-grow-1">
      <div class="container-fluid px-4 py-4">

        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
          <div>
            <h1 class="h3 mb-1">
              <i class="bi me-2 text-primary"></i>Dashboard
            </h1>
            <p class="text-muted mb-0 small">Manage and monitor family registrations</p>
          </div>
          <div class="d-flex gap-2">
            <div class="dropdown">
              <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bi bi-download me-2"></i>Export
              </button>
              <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                  <a class="dropdown-item" href="/admin/export/excel">
                    <i class="bi bi-file-earmark-excel text-success me-2"></i>Export to Excel
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="#" onclick="openPdfExportModal(); return false;">
                    <i class="bi bi-file-earmark-pdf text-danger me-2"></i>Export to PDF
                  </a>
                </li>
              </ul>
            </div>
            <a href="/admin/create-family" class="btn btn-primary">
              <i class="bi bi-plus-circle me-2"></i>Add Family
            </a>
          </div>
        </div>

        <!-- Alert Messages -->
        <% if (locals.updated) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            <strong>Success!</strong> Family details updated successfully.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          <% } %>

            <% if (locals.deleted) { %>
              <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="bi bi-info-circle-fill me-2"></i>
                <strong>Deleted!</strong> Family has been removed from the system.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
              <% } %>

                <% if (locals.message) { %>
                  <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <%= locals.message %>
                      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                  </div>
                  <% } %>

                    <!-- Statistics Cards -->
                    <% if (stats) { %>
                      <div class="row g-3 mb-4">
                        <div class="col-12 col-sm-6 col-xl-3">
                          <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                              <div class="d-flex justify-content-between align-items-center">
                                <div>
                                  <p class="text-muted mb-1 small fw-medium">Total Families</p>
                                  <h3 class="mb-0 fw-bold">
                                    <%= stats.totalFamilies %>
                                  </h3>
                                </div>
                                <div class="rounded-circle p-3" style="background: rgba(79, 70, 229, 0.1);">
                                  <i class="bi bi-people-fill fs-4 text-primary"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="col-12 col-sm-6 col-xl-3">
                          <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                              <div class="d-flex justify-content-between align-items-center">
                                <div>
                                  <p class="text-muted mb-1 small fw-medium">Total Members</p>
                                  <h3 class="mb-0 fw-bold">
                                    <%= stats.totalMembers %>
                                  </h3>
                                </div>
                                <div class="rounded-circle p-3" style="background: rgba(16, 185, 129, 0.1);">
                                  <i class="bi bi-person-check-fill fs-4 text-success"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="col-12 col-sm-6 col-xl-3">
                          <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                              <div class="d-flex justify-content-between align-items-center">
                                <div>
                                  <p class="text-muted mb-1 small fw-medium">Total Children</p>
                                  <h3 class="mb-0 fw-bold">
                                    <%= stats.totalChildren %>
                                  </h3>
                                </div>
                                <div class="rounded-circle p-3" style="background: rgba(245, 158, 11, 0.1);">
                                  <i class="bi bi-emoji-smile-fill fs-4 text-warning"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>

                        <div class="col-12 col-sm-6 col-xl-3">
                          <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                              <div class="d-flex justify-content-between align-items-center">
                                <div>
                                  <p class="text-muted mb-1 small fw-medium">Recent (7 days)</p>
                                  <h3 class="mb-0 fw-bold">
                                    <%= stats.recentFamilies %>
                                  </h3>
                                </div>
                                <div class="rounded-circle p-3" style="background: rgba(239, 68, 68, 0.1);">
                                  <i class="bi bi-calendar-check-fill fs-4 text-danger"></i>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                      <% } %>

                        <!-- Search & Filter -->
                        <div class="card border-0 shadow-sm mb-4">
                          <div class="card-body py-3">
                            <%- include('search-filter-form') %>
                          </div>
                        </div>

                        <!-- Family List -->
                        <div class="card border-0 shadow-sm mb-4">
                          <% if (results && results.length> 0) { %>
                            <div class="table-responsive">
                              <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                  <tr>
                                    <th class="px-4 py-3 border-0">Family Head</th>
                                    <th class="py-3 border-0">Location</th>
                                    <th class="py-3 border-0">Occupation</th>
                                    <th class="py-3 border-0 text-center">Children</th>
                                    <th class="py-3 border-0 text-center">Family Tree</th>
                                    <th class="py-3 border-0 text-end px-4">Actions</th>
                                  </tr>
                                </thead>
                                <tbody>
                                  <% results.forEach(member=> { %>
                                    <tr style="cursor: pointer;" onclick="location='/admin/view/<%= member.id %>'">
                                      <td class="px-4 py-3">
                                        <div class="d-flex align-items-center gap-2">
                                          <div class="rounded-circle bg-primary bg-opacity-10 p-2">
                                            <i class="bi bi-person-fill text-primary"></i>
                                          </div>
                                          <span class="fw-semibold">
                                            <%= member.name %>
                                          </span>
                                        </div>
                                      </td>
                                      <td class="py-3">
                                        <div class="text-muted small">
                                          <i class="bi bi-geo-alt-fill me-1"></i>
                                          <%= member.district %>, <%= member.state %>
                                        </div>
                                      </td>
                                      <td class="py-3">
                                        <span class="text-muted small">
                                          <i class="bi bi-briefcase-fill me-1"></i>
                                          <%= member.occupation || 'N/A' %>
                                        </span>
                                      </td>
                                      <td class="py-3 text-center">
                                        <span class="badge bg-light text-dark border">
                                          <i class="bi bi-people-fill me-1"></i>
                                          <%= member.children_count || 0 %>
                                        </span>
                                      </td>
                                      <td class="py-3 text-center">
                                        <button class="family-tree-btn"
                                          onclick="event.stopPropagation(); viewFamilyTree('<%= member.id %>')">
                                          <i class="bi bi-diagram-3 me-1"></i>View Tree
                                        </button>
                                      </td>
                                      <td class="py-3 text-end px-4">
                                        <div class="d-flex gap-2 justify-content-end">
                                          <button class="btn btn-sm btn-outline-primary"
                                            onclick="event.stopPropagation(); location='/admin/view/<%= member.id %>'"
                                            title="View">
                                            <i class="bi bi-eye"></i>
                                          </button>
                                          <button class="btn btn-sm btn-outline-secondary"
                                            onclick="event.stopPropagation(); location='/admin/edit/<%= member.id %>'"
                                            title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                          </button>
                                          <button class="btn btn-sm btn-outline-danger"
                                            onclick="event.stopPropagation(); confirmDelete('<%= member.id %>', '<%= member.name %>')"
                                            title="Delete">
                                            <i class="bi bi-trash"></i>
                                          </button>
                                        </div>
                                      </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                              </table>
                            </div>
                            <% } else { %>
                              <div class="card-body text-center py-5">
                                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                                <h5 class="text-muted">No families found</h5>
                                <p class="text-muted small mb-3">Try adjusting your search or filter criteria</p>
                                <a href="/admin/dashboard" class="btn btn-primary">
                                  <i class="bi bi-arrow-clockwise me-2"></i>Reset Filters
                                </a>
                              </div>
                              <% } %>
                        </div>

                        <!-- Pagination -->
                        <% if (totalPages> 1) { %>
                          <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                              <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link"
                                  href="?page=<%= currentPage - 1 %>&q=<%= searchValue %>&state=<%= selectedState %>&district=<%= selectedDistrict %>">
                                  <i class="bi bi-chevron-left"></i>
                                </a>
                              </li>

                              <% for (let i=1; i <=totalPages; i++) { %>
                                <% if (i===1 || i===totalPages || (i>= currentPage - 1 && i <= currentPage + 1)) { %>
                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                      <a class="page-link"
                                        href="?page=<%= i %>&q=<%= searchValue %>&state=<%= selectedState %>&district=<%= selectedDistrict %>">
                                        <%= i %>
                                      </a>
                                    </li>
                                    <% } else if (i===currentPage - 2 || i===currentPage + 2) { %>
                                      <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                      </li>
                                      <% } %>
                                        <% } %>

                                          <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                            <a class="page-link"
                                              href="?page=<%= currentPage + 1 %>&q=<%= searchValue %>&state=<%= selectedState %>&district=<%= selectedDistrict %>">
                                              <i class="bi bi-chevron-right"></i>
                                            </a>
                                          </li>
                            </ul>
                          </nav>
                          <% } %>

      </div>
    </main>

    <%- include('../partials/footer') %>

      <!-- Family Tree Modal -->
      <div class="modal fade family-tree-modal" id="familyTreeModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">
                <i class="bi bi-diagram-3 me-2"></i>Family Tree
              </h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="familyTreeContent">
              <div class="loading-spinner">
                <div class="spinner-border text-primary" role="status">
                  <span class="visually-hidden">Loading...</span>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Delete Confirmation Modal -->
      <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header border-0">
              <h5 class="modal-title">
                <i class="bi bi-exclamation-triangle text-warning me-2"></i>Confirm Delete
              </h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <p id="deleteMessage" class="mb-0">Are you sure you want to delete this family?</p>
            </div>
            <div class="modal-footer border-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                <i class="bi bi-trash me-2"></i>Delete
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- PDF Export Modal -->
      <div class="modal fade" id="pdfExportModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header border-0">
              <h5 class="modal-title">
                <i class="bi bi-file-earmark-pdf text-danger me-2"></i>Export to PDF
              </h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label for="stateSelect" class="form-label">Select State</label>
                <select class="form-select" id="stateSelect" onchange="loadDistricts()">
                  <option value="">Choose state...</option>
                  <option value="all">All States</option>
                  <% if (states && states.length> 0) { %>
                    <% states.forEach(function(state) { %>
                      <option value="<%= state %>">
                        <%= state %>
                      </option>
                      <% }); %>
                        <% } %>
                </select>
              </div>
              <div class="mb-3">
                <label for="districtSelect" class="form-label">Select District</label>
                <select class="form-select" id="districtSelect" disabled>
                  <option value="">Choose district...</option>
                </select>
              </div>
            </div>
            <div class="modal-footer border-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="button" class="btn btn-danger" id="downloadPdfBtn" onclick="downloadPdf()" disabled>
                <i class="bi bi-download me-2"></i>Download PDF
              </button>
            </div>
          </div>
        </div>
      </div>

      <%- include('../partials/scripts') %>

        <script>
          let deleteFamilyId = null;
          const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
          const treeModal = new bootstrap.Modal(document.getElementById('familyTreeModal'));

          // View Family Tree
          async function viewFamilyTree(userId) {
            const modalContent = document.getElementById('familyTreeContent');
            modalContent.innerHTML = '<div class="loading-spinner"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
            treeModal.show();

            try {
              const response = await fetch(`/api/family-tree-simple/${userId}`);
              const result = await response.json();

              if (result.success && result.tree) {
                modalContent.innerHTML = renderFamilyTree(result.tree);
              } else {
                modalContent.innerHTML = '<div class="text-center py-5"><i class="bi bi-exclamation-triangle fs-1 text-warning"></i><p class="mt-3">No family tree found</p></div>';
              }
            } catch (error) {
              console.error('Error fetching family tree:', error);
              modalContent.innerHTML = '<div class="text-center py-5"><i class="bi bi-x-circle fs-1 text-danger"></i><p class="mt-3">Error loading family tree</p></div>';
            }
          }

          // Render Family Tree HTML
          function renderFamilyTree(tree) {
            if (!tree) return '<p class="text-muted">No data</p>';

            let html = '<div class="tree-container">';

            // Grandparents Level (if exists)
            if (tree.parents && tree.parents.members && tree.parents.members.length > 0) {
              html += '<div class="tree-level mb-4">';
              html += '<div class="tree-node">';
              const father = tree.parents.members.find(m => m.relation_type === 'father');
              if (father) {
                html += renderMemberNode(father);
              }
              html += '</div></div>';

              html += '<div class="tree-connector"></div>';
            }

            // Parents Level (Husband + Wife)
            html += '<div class="tree-level">';

            // Husband's side
            html += '<div class="tree-node">';
            const husband = tree.members?.find(m => m.relation_type === 'husband');
            if (husband) {
              html += renderMemberNode(husband);
            }
            html += '</div>';

            // Spouse connection
            html += '<div style="align-self:center;font-size:20px;">❤️</div>';

            // Wife's side
            html += '<div class="tree-node">';
            const wife = tree.members?.find(m => m.relation_type === 'wife');
            if (wife) {
              html += renderMemberNode(wife);
            }
            html += '</div>';

            html += '</div>';

            // Parents' Parents (In-laws)
            if (tree.spouse && tree.spouse.members) {
              const spouseFather = tree.spouse.members.find(m => m.relation_type === 'father');
              if (spouseFather) {
                html += '<div class="tree-connector"></div>';
                html += '<div class="tree-level">';
                html += '<div class="tree-node">';
                html += renderMemberNode(spouseFather);
                html += '</div></div>';
              }
            }

            // Children Level
            const immediateChildren = tree.members?.filter(m => m.member_type === 'child' || m.relation_type === 'son' || m.relation_type === 'daughter') || [];
            if (immediateChildren.length > 0 || (tree.children && tree.children.length > 0)) {
              html += '<div class="tree-connector"></div>';
              html += '<div class="tree-level">';

              // Render immediate children from family_members
              immediateChildren.forEach(childMember => {
                html += '<div class="tree-node">';
                html += renderMemberNode(childMember);
                html += '</div>';
              });

              // Render child families (if any)
              if (tree.children && tree.children.length > 0) {
                tree.children.forEach(child => {
                  const childMember = child.members?.find(m => m.relation_type === 'son' || m.relation_type === 'daughter');
                  if (childMember) {
                    html += '<div class="tree-node">';
                    html += renderMemberNode(childMember);
                    html += '</div>';
                  }
                });
              }

              html += '</div>';
            }

            // Siblings Level (including their children)
            if (tree.siblings && tree.siblings.length > 0) {
              html += '<hr class="my-4">';
              html += '<h6 class="mb-3">Siblings & Their Children</h6>';
              html += '<div class="tree-level flex-wrap">';

              tree.siblings.forEach(sibling => {
                const siblingMember = sibling.members?.find(m => m.relation_type === 'brother' || m.relation_type === 'sister' || m.member_type === 'sibling');
                if (siblingMember) {
                  html += '<div class="d-flex flex-column align-items-center mb-4">';
                  html += '<div class="tree-node border border-info border-2">';
                  html += renderMemberNode(siblingMember);
                  html += '</div>';

                  // Render Sibling's Children
                  const siblingChildren = sibling.members?.filter(m => m.member_type === 'child' || m.relation_type === 'son' || m.relation_type === 'daughter') || [];
                  if (siblingChildren.length > 0) {
                    html += '<div class="tree-connector"></div>';
                    html += '<div class="d-flex gap-3">';
                    siblingChildren.forEach(sc => {
                      html += '<div class="tree-node bg-light">';
                      html += renderMemberNode(sc);
                      html += '</div>';
                    });
                    html += '</div>';
                  }
                  html += '</div>';
                }
              });

              html += '</div>';
            }

            html += '</div>';
            return html;
          }

          // Render individual member node
          function renderMemberNode(member) {
            let photoHtml = '';
            if (member.photo) {
              const photoSrc = '/uploads/' + member.photo;
              photoHtml = `<img src="${photoSrc}" alt="${member.name}" class="tree-photo" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`;
            }
            photoHtml += `<div class="tree-photo-placeholder" style="${member.photo ? 'display:none;' : ''}"><i class="bi bi-person text-muted"></i></div>`;

            return `
        ${photoHtml}
        <div class="tree-name">${member.name || 'N/A'}</div>
        <div class="tree-relation">${member.relation_type || member.relationship || ''}</div>
      `;
          }

          function confirmDelete(familyId, familyName) {
            deleteFamilyId = familyId;
            document.getElementById('deleteMessage').textContent =
              `Are you sure you want to delete the family "${familyName}"? This action cannot be undone.`;
            deleteModal.show();
          }

          document.getElementById('confirmDeleteBtn').addEventListener('click', function () {
            if (!deleteFamilyId) return;
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/admin/delete/' + deleteFamilyId;
            document.body.appendChild(form);
            form.submit();
          });

          function openPdfExportModal() {
            const modal = new bootstrap.Modal(document.getElementById('pdfExportModal'));
            modal.show();
          }

          async function loadDistricts() {
            const stateSelect = document.getElementById('stateSelect');
            const districtSelect = document.getElementById('districtSelect');
            const selectedState = stateSelect.value;

            districtSelect.innerHTML = '<option value="">Choose district...</option>';
            districtSelect.disabled = true;

            if (selectedState && selectedState !== 'all') {
              try {
                const response = await fetch('/data/india-states-districts.json');
                const data = await response.json();
                const districts = data[selectedState] || [];

                const allOption = document.createElement('option');
                allOption.value = 'all';
                allOption.textContent = 'All Districts';
                districtSelect.appendChild(allOption);

                districts.forEach(district => {
                  const option = document.createElement('option');
                  option.value = district;
                  option.textContent = district;
                  districtSelect.appendChild(option);
                });

                districtSelect.disabled = false;
              } catch (error) {
                console.error('Error loading districts:', error);
              }
            } else if (selectedState === 'all') {
              const allOption = document.createElement('option');
              allOption.value = 'all';
              allOption.textContent = 'All Districts';
              districtSelect.appendChild(allOption);
              districtSelect.value = 'all';
              districtSelect.disabled = true;
            }

            updateDownloadButton();
          }

          function updateDownloadButton() {
            const stateSelect = document.getElementById('stateSelect');
            const districtSelect = document.getElementById('districtSelect');
            const downloadBtn = document.getElementById('downloadPdfBtn');
            downloadBtn.disabled = !stateSelect.value || !districtSelect.value;
          }

          document.getElementById('districtSelect').addEventListener('change', updateDownloadButton);

          function downloadPdf() {
            const state = document.getElementById('stateSelect').value;
            const district = document.getElementById('districtSelect').value;

            if (state && district) {
              window.location.href = `/admin/export/pdf?state=${encodeURIComponent(state)}&district=${encodeURIComponent(district)}`;
              const modal = bootstrap.Modal.getInstance(document.getElementById('pdfExportModal'));
              modal.hide();
            }
          }
        </script>

</body>

</html>